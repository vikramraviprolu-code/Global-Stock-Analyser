# EquityScope environment variables
# All variables are OPTIONAL — the app runs without any keys.
# Copy to `.env` and override only what you need.

# Flask
# FLASK_ENV=production
# FLASK_DEBUG=0
# PORT=5050

# Cache TTLs (seconds)
# PRICE_CACHE_TTL=1800     # 30 min
# FX_CACHE_TTL=21600       # 6 hours

# Future: paid data tiers (none required today)
# FINNHUB_API_KEY=
# POLYGON_API_KEY=
# ALPHAVANTAGE_API_KEY=
